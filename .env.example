# ─────────────────────────────────────────────────────────────────────────────
# Motuva remove-bg pipeline — environment template.  Copy to `a.env` and fill in.
#
#   cp .env.example a.env
#
# The package loads `a.env` from the package root (config/pipeline_config.py),
# so it works no matter which directory you launch from. `a.env` is gitignored;
# this template (.env.example) is the only env file committed to git.
#
# All MOTOCUT_-prefixed vars override fields on PipelineSettings (config/
# pipeline_config.py). REMOVE_BG_API_KEY is read WITHOUT the prefix. Nested
# sub-config fields use a double underscore, e.g.
#   MOTOCUT_REMOVEBG__EXTERIOR_ADD_SHADOW=false
#
# The values you almost always must set are MOTOCUT_BLENDER_EXE, REMOVE_BG_API_KEY,
# and the batch I/O dirs.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secret (fill this in; leave it OUT of git) ────────────────────────────────
# remove.bg API key — REQUIRED for ALL lanes: interior, exterior-partial, AND the
# exterior-full car cutout (the exterior-full lane now removes the car background
# and composites it onto the rendered plate — no diffusion model).
REMOVE_BG_API_KEY=

# ── Blender — REQUIRED: path to the Blender 5.x executable ─────────────────────
# On a Linux pod use a Linux path, e.g. /workspace/blender-5.0/blender
MOTOCUT_BLENDER_EXE=/path/to/blender
# Optional overrides (default into the package):
# MOTOCUT_STUDIO_ENGINE_DIR=
# MOTOCUT_MASTER_BLEND=
# MOTOCUT_MATERIALS_2K_DIR=
# Stop the warm Blender worker after each plate render to free Cycles VRAM before FLUX.
# MOTOCUT_BLENDER__RELEASE_AFTER_RENDER=true

# ── Model weights / index (default into assets/) ─────────────────────────────
# MOTOCUT_CLASSIFIER_WEIGHTS=
# MOTOCUT_ORIENTATION_WEIGHTS=
# MOTOCUT_YOLO_WEIGHTS=yolov8s.pt
# MOTOCUT_INDEX_DIR=

# ── Batch I/O (main.py / the batch runner) ────────────────────────────────────
MOTOCUT_INPUT_DIR=
MOTOCUT_OUTPUT_DIR=
# Supplied background image used by the exterior-partial lane only (optional).
MOTOCUT_BACKGROUND_IMAGE=

# ── exterior-full manual composite ────────────────────────────────────────────
# Exterior-full uses a local plate-aware contact shadow by default.
# MOTOCUT_REMOVEBG__EXTERIOR_ADD_SHADOW=false
# Placement: the car is pinned by its WHEEL-FOOTPRINT centre onto the plate's
# turntable centre, then slid TOWARD the camera (forward bias, a fraction of the disc
# RADIUS) per pose group. 0.0 = pure grounding (car centred on the turntable).
# MOTOCUT_ANCHOR__FORWARD_BIAS_FRONTREAR=0.25
# MOTOCUT_ANCHOR__FORWARD_BIAS_THREEQ=0.17
# MOTOCUT_ANCHOR__FORWARD_BIAS_SIDE=0.27
# Camera sensor width (mm) assumed by the plate — MUST match the master .blend camera.
# MOTOCUT_ANCHOR__SENSOR_MM=36.0

# Server-only rembg + FLUX Fill experiment. The batch runner still uses remove.bg.
# rembg downloads model weights on first use to ~/.u2net unless U2NET_HOME is set.
# MOTOCUT_REMBG__MODEL_NAME=birefnet-general
# MOTOCUT_REMBG__ALPHA_MATTING=true
# MOTOCUT_REMBG__CLEAN_MASK=true
# MOTOCUT_REMBG__MORPH_KERNEL=7
# MOTOCUT_REMBG__FEATHER_PX=3
# MOTOCUT_REMBG__PRESERVE_ERODE_PX=5
# MOTOCUT_REMBG__EDGE_BAND_PX=18
# MOTOCUT_REMBG__EDGE_INPAINT_RADIUS_PX=3
# MOTOCUT_REMBG__COLOR_MATCH_STRENGTH=0.22
# MOTOCUT_REMBG__COLOR_MATCH_BAND_PX=24
# MOTOCUT_REMBG__EDGE_PLATE_BLEND=0.18
# MOTOCUT_REMBG__SHADOW_OFFSET_FRAC=0.08
# MOTOCUT_REMBG__SHADOW_HEIGHT_FRAC=0.18
# MOTOCUT_REMBG__SHADOW_WIDTH_FRAC=0.84
# MOTOCUT_REMBG__SHADOW_BLUR_PX=18
# MOTOCUT_REMBG__CONTACT_SHADOW_OPACITY=0.34
# MOTOCUT_INPAINT__ENABLED=false
# MOTOCUT_INPAINT__MODEL_ID=black-forest-labs/FLUX.1-Fill-dev
# MOTOCUT_INPAINT__MODE=shadow_edge
# MOTOCUT_INPAINT__MAX_LONG_EDGE=1024
# MOTOCUT_INPAINT__NUM_STEPS=28
# MOTOCUT_INPAINT__SEED=
# MOTOCUT_INPAINT__BODY_OPACITY=0.35
# MOTOCUT_INPAINT__PROMPT=Create a natural soft studio contact shadow beneath the tires and repair only the cutout edge transition into the floor and background. Preserve the car identity, paint color, silhouette, wheels, lights, glass, trim, and details.

# Final FLUX.2 Klein image-edit refinement (server exterior-full only).
# This is NOT inpainting: the server passes the rembg composite plus the final gray
# YOLO placement guide to FLUX, then returns the full-frame refined composite.
# MOTOCUT_FLUX_REFINE__ENABLED=false
# MOTOCUT_FLUX_REFINE__MODEL_ID=black-forest-labs/FLUX.2-klein-9B
# MOTOCUT_FLUX_REFINE__REFERENCE_MODE=both
# MOTOCUT_FLUX_REFINE__MAX_LONG_EDGE=768
# MOTOCUT_FLUX_REFINE__NUM_STEPS=4
# MOTOCUT_FLUX_REFINE__GUIDANCE_SCALE=1.0
# MOTOCUT_FLUX_REFINE__STRENGTH=
# MOTOCUT_FLUX_REFINE__SEED=
# Full GPU is faster after Blender is released; set true only if FLUX still OOMs.
# MOTOCUT_FLUX_REFINE__CPU_OFFLOAD=false
# Optional override; leave empty to use the mode-specific prompt below.
# MOTOCUT_FLUX_REFINE__PROMPT=
# MOTOCUT_FLUX_REFINE__PROMPT_COMPOSITE_ONLY=Locked-background automotive composite repair. Keep every non-car background pixel unchanged; repair only car edges, color, reflections, tire grounding, and shadow.
# MOTOCUT_FLUX_REFINE__PROMPT_WITH_REFERENCE=Locked-background automotive composite repair using references. Keep every non-car background pixel unchanged; use guide/reference only for car placement and identity; repair only car integration defects.

# ── Small-model inference / concurrency / observability ───────────────────────
# MOTOCUT_SMALL_MODEL_DTYPE=float16
# MOTOCUT_PREPROCESS_WORKERS=8
# MOTOCUT_REMOVEBG_CONCURRENCY=4
# MOTOCUT_LOG_LEVEL=INFO
# MOTOCUT_ENVIRONMENT=prod
