# ─────────────────────────────────────────────────────────────────────────────
# Motuva remove-bg pipeline — environment template.  Copy to `a.env` and fill in.
#
#   cp .env.example a.env
#
# The package loads `a.env` from the package root (config/pipeline_config.py),
# so it works no matter which directory you launch from. `a.env` is gitignored;
# this template (.env.example) is the only env file committed to git.
#
# All MOTOCUT_-prefixed vars override fields on PipelineSettings (config/
# pipeline_config.py). REMOVE_BG_API_KEY is read WITHOUT the prefix. Nested
# sub-config fields use a double underscore, e.g.
#   MOTOCUT_REMOVEBG__EXTERIOR_ADD_SHADOW=true
#
# The values you almost always must set are MOTOCUT_BLENDER_EXE, REMOVE_BG_API_KEY,
# and the batch I/O dirs.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secret (fill this in; leave it OUT of git) ────────────────────────────────
# remove.bg API key — REQUIRED for ALL lanes: interior, exterior-partial, AND the
# exterior-full car cutout (the exterior-full lane now removes the car background
# and composites it onto the rendered plate — no diffusion model).
REMOVE_BG_API_KEY=

# ── Blender — REQUIRED: path to the Blender 5.x executable ─────────────────────
# On a Linux pod use a Linux path, e.g. /workspace/blender-5.0/blender
MOTOCUT_BLENDER_EXE=/path/to/blender
# Optional overrides (default into the package):
# MOTOCUT_STUDIO_ENGINE_DIR=
# MOTOCUT_MASTER_BLEND=
# MOTOCUT_MATERIALS_2K_DIR=

# ── Model weights / index (default into assets/) ─────────────────────────────
# MOTOCUT_CLASSIFIER_WEIGHTS=
# MOTOCUT_ORIENTATION_WEIGHTS=
# MOTOCUT_YOLO_WEIGHTS=yolov8s.pt
# MOTOCUT_INDEX_DIR=

# ── Batch I/O (main.py / the batch runner) ────────────────────────────────────
MOTOCUT_INPUT_DIR=
MOTOCUT_OUTPUT_DIR=
# Supplied background image used by the exterior-partial lane only (optional).
MOTOCUT_BACKGROUND_IMAGE=

# ── exterior-full manual composite ────────────────────────────────────────────
# Paste a remove.bg drop shadow under the car for grounding (default true).
# MOTOCUT_REMOVEBG__EXTERIOR_ADD_SHADOW=true
# Placement: the car is pinned by its WHEEL-FOOTPRINT centre onto the plate's
# turntable centre, then slid TOWARD the camera (forward bias, a fraction of the disc
# RADIUS) per pose group. 0.0 = pure grounding (car centred on the turntable).
# MOTOCUT_ANCHOR__FORWARD_BIAS_FRONTREAR=0.25
# MOTOCUT_ANCHOR__FORWARD_BIAS_THREEQ=0.17
# MOTOCUT_ANCHOR__FORWARD_BIAS_SIDE=0.27
# Camera sensor width (mm) assumed by the plate — MUST match the master .blend camera.
# MOTOCUT_ANCHOR__SENSOR_MM=36.0

# ── Small-model inference / concurrency / observability ───────────────────────
# MOTOCUT_SMALL_MODEL_DTYPE=float16
# MOTOCUT_PREPROCESS_WORKERS=8
# MOTOCUT_REMOVEBG_CONCURRENCY=4
# MOTOCUT_LOG_LEVEL=INFO
# MOTOCUT_ENVIRONMENT=prod
